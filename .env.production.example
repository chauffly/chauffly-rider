# Chauffly Rider App — Production environment (EAS Build)
# Copy to .env.production — Expo uses this when building with --profile production.
# All EXPO_PUBLIC_ variables are bundled into the app binary at build time.

EXPO_PUBLIC_APP_NAME=Chauffly
EXPO_PUBLIC_APP_ENV=production

EXPO_PUBLIC_API_BASE_URL=https://api.chauffly.com
EXPO_PUBLIC_API_PREFIX=/api/v1
EXPO_PUBLIC_SOCKET_BASE_URL=https://api.chauffly.com
EXPO_PUBLIC_SOCKET_PATH=/socket.io
EXPO_PUBLIC_REQUEST_TIMEOUT_MS=15000

EXPO_PUBLIC_ENABLE_API_LOGS=false
EXPO_PUBLIC_ENABLE_SOCKET_DEBUG=false

EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
EXPO_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_your-paystack-public-key
